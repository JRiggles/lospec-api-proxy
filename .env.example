# Example .env file for Lospec API Proxy

### REQUIRED
LOSPEC_API_KEY=your-api-key-here

### OPTIONAL
# leave this empty to allow all User-Agentsm, or set to a specific string to require that exact
# header value
REQUIRED_USER_AGENT=""

# cache TTL in seconds for CDN (default: 86400 = 24 hours)
CACHE_TTL=86400
# stale-while-revalidate TTL in seconds (default: 3600 = 1 hour)
SWR_TTL=3600

# upstream fetch timeout in milliseconds (default: 5000)
FETCH_TIMEOUT_MS=5000
